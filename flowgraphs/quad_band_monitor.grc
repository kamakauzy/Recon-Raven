    minoutbuf: '0'
    showports: 'False'
    legend: 'True'
    axislabels: 'True'
    grid: 'True'
    color1: '0'
    alpha1: '1.0'
  states:
    coordinate: [360, 580]
    rotation: 0
    state: enabled

- name: fft_ism
