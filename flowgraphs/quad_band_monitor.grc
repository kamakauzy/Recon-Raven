    name: '"ISM Spectrum"'
    nconnections: '1'
    type: complex
    update_time: '0.10'
    wintype: window.WIN_BLACKMAN_hARRIS
    ymin: '-120'
    ymax: '10'
    autoscale: 'False'
    average: '1.0'
    maxoutbuf: '0'
    minoutbuf: '0'
    showports: 'False'
    legend: 'False'
    axislabels: 'True'
    grid: 'True'
    ctrlpanel: 'False'
    label: Relative Gain
    units: dB
    color1: '"green"'
    width1: '1'
    alpha1: '1.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_level: '0.0'
    tr_chan: '0'
    tr_tag: '""'
    norm_window: 'False'
  states:
    coordinate: [360, 740]
    rotation: 0
    state: enabled

